{
  "name": "yv-platform-i18n",
  "version": "0.1.0",
  "private": true,
  "description": "YouVersion multi-platform i18n monorepo",
  "scripts": {
    "generate": "tsx scripts/generate-platform-sources.ts",
    "validate": "tsx scripts/validate-keys.ts",
    "check-coverage": "tsx scripts/check-coverage.ts",
    "assemble:android": "bash scripts/assemble-android.sh",
    "assemble:ios": "bash scripts/assemble-ios.sh",
    "assemble:react": "bash scripts/assemble-react.sh",
    "assemble": "npm run assemble:android && npm run assemble:ios && npm run assemble:react",
    "prebuild": "npm run generate && npm run validate && npm run assemble"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
